# ══════════════════════════════════════════════════════════════
#  teslamate-supercharger-costs — configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control!
# ══════════════════════════════════════════════════════════════

# ── Tesla account ──────────────────────────────────────────────
# The email address you use to log in to your Tesla account
TESLA_EMAIL=your@email.com

# Where to persist the OAuth token between runs.
# This path is inside the container — map it to a host volume.
TESLA_CACHE_FILE=/data/tesla_cache.json

# (Optional) VIN of the vehicle to import costs for.
# If not set, the first vehicle in your account is used.
# Useful for households with multiple Teslas.
# TESLA_VIN=5YJ3E7EB0KF000000

# ── TeslaMate database ─────────────────────────────────────────
# The hostname must match the service name in your TeslaMate
# docker-compose.yml (usually "database").
TESLAMATE_DB_HOST=database
TESLAMATE_DB_PORT=5432
TESLAMATE_DB_NAME=teslamate
TESLAMATE_DB_USER=teslamate
TESLAMATE_DB_PASS=your_database_password_here

# ── Importer behaviour ─────────────────────────────────────────
# How many days back to fetch from the Tesla API on each run.
# Increase for a one-time historical backfill (e.g. 365).
LOOKBACK_DAYS=30

# Maximum difference in seconds between Tesla API start time
# and TeslaMate's recorded start time to count as a match.
# Increase to 300 if you see many "NOT FOUND" warnings.
TIME_TOLERANCE_S=120

# Set to "true" to overwrite costs that TeslaMate already has.
# Useful if you want to force a re-import of corrected data.
OVERWRITE_EXISTING=false

# ── Logging ────────────────────────────────────────────────────
LOG_FILE=/logs/importer.log
